# Copy this file to collector.env and fill in the same PocketBase account
# used by Slab Ledger. Do not share collector.env or commit it to Git.
SLAB_POCKETBASE_URL=https://your-pocketbase-host.example
SLAB_POCKETBASE_EMAIL=you@example.com
SLAB_POCKETBASE_PASSWORD=replace-this

# Standard Chromium is the default because eBay sold results are rendered in
# the browser. Set to requests only for troubleshooting.
SLAB_SCRAPER_BACKEND=browser

# 1 keeps Chromium in the background. Set to 0 temporarily when diagnosing a
# page or completing a normal browser sign-in/check yourself.
SLAB_BROWSER_HEADLESS=1
